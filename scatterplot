   "source": "def validate_custom_weights(custom_weights):\n    normalized = {}\n    for raw_line, sector_weights in custom_weights.items():\n        line = int(raw_line)\n        allowed = {sector for sector, mapped_line in BTOS_TO_PCE_LINE.items() if int(mapped_line) == line}\n        unknown = set(map(str, sector_weights)) - allowed\n        if unknown:\n            raise ValueError(f\"Custom weights for PCE line {line} include unmapped sectors: {sorted(unknown)}\")\n        normalized[line] = {str(sector): float(weight) for sector, weight in sector_weights.items()}\n        if any(weight < 0 for weight in normalized[line].values()):\n            raise ValueError(f\"Custom weights for PCE line {line} must be nonnegative\")\n    return normalized\n\n\ndef aggregate_sector_ai_to_pce_line(sector_monthly, custom_weights=None):\n    custom_weights = validate_custom_weights(custom_weights or {})\n    pieces = []\n\n    for (line, month), group in sector_monthly.groupby([\"pce_line\", \"month\"], sort=True):\n        group = group.copy()\n        line = int(line)\n        if line in custom_weights:\n            raw_weights = group[\"sector\"].map(custom_weights[line])\n            if raw_weights.isna().any():\n                missing = sorted(group.loc[raw_weights.isna(), \"sector\"].unique())\n                raise ValueError(f\"Missing custom within-line weights for PCE line {line}: {missing}\")\n            group[\"within_line_weight_raw\"] = raw_weights.astype(float)\n        else:\n            group[\"within_line_weight_raw\"] = 1.0\n\n        total = group[\"within_line_weight_raw\"].sum()\n        if total <= 0:\n            raise ValueError(f\"Within-line weights sum to zero for PCE line {line}, month {month:%Y-%m}\")\n        group[\"within_line_weight\"] = group[\"within_line_weight_raw\"] / total\n        group[\"weighted_ai\"] = group[\"ai_adoption\"] * group[\"within_line_weight\"]\n        pieces.append(pd.DataFrame({\n            \"pce_line\": [line],\n            \"month\": [month],\n            \"line_ai_adoption\": [group[\"weighted_ai\"].sum()],\n            \"contributing_sectors\": [\", \".join(group[\"sector\"].tolist())],\n            \"contributing_sector_count\": [group[\"sector\"].nunique()],\n            \"within_line_method\": [\"custom\" if line in custom_weights else \"equal_valid_sector\"],\n            \"n_btos_waves\": [group[\"n_btos_waves\"].sum()],\n        }))\n\n    return pd.concat(pieces, ignore_index=True)\n\n\npce_line_ai = aggregate_sector_ai_to_pce_line(btos_monthly_sector, WITHIN_LINE_SECTOR_WEIGHTS)\n\nline_ai_coverage = (\n    pce_line_ai.groupby(\"pce_line\", as_index=False)\n    .agg(\n        first_month=(\"month\", \"min\"),\n        last_month=(\"month\", \"max\"),\n        months=(\"month\", \"nunique\"),\n        min_contributing_sectors=(\"contributing_sector_count\", \"min\"),\n        max_contributing_sectors=(\"contributing_sector_count\", \"max\"),\n    )\n)\nline_ai_coverage\n"
  },
