   "source": "def bea_years_needed(start_date=PCE_START_DATE):\n    start = pd.Timestamp(start_date)\n    # Pull the prior year so January starts still have lagged expenditure shares and m/m price changes.\n    first_year = start.year - 1\n    last_year = pd.Timestamp.today().year\n    return list(range(first_year, last_year + 1))\n\n\ndef bea_cache_path(table_name, frequency, years):\n    year_label = f\"{min(years)}-{max(years)}\"\n    return DATA / f\"bea_NIUnderlyingDetail_{table_name}_{frequency}_{year_label}.json\"\n\n\ndef fetch_bea_table(table_name, years, frequency=\"M\", force=False):\n    cache = bea_cache_path(table_name, frequency, years)\n    if cache.exists() and not force:\n        print(f\"cached    {cache.name}\")\n        return pd.read_json(cache)\n\n    params = {\n        \"UserID\": read_bea_key(),\n        \"method\": \"GetData\",\n        \"datasetname\": \"NIUnderlyingDetail\",\n        \"TableName\": table_name,\n        \"Frequency\": frequency,\n        \"Year\": \",\".join(str(year) for year in years),\n        \"ResultFormat\": \"JSON\",\n    }\n    url = f\"{BEA_BASE_URL}?{urlencode(params)}\"\n    request = Request(url, headers={\"User-Agent\": \"Mozilla/5.0\"})\n    with urlopen(request, timeout=120) as response:\n        payload = json.loads(response.read().decode(\"utf-8\"))\n\n    results = payload.get(\"BEAAPI\", {}).get(\"Results\", {})\n    if \"Error\" in results:\n        raise RuntimeError(results[\"Error\"])\n    data = pd.DataFrame(results.get(\"Data\", []))\n    if data.empty:\n        raise RuntimeError(f\"BEA returned no rows for {table_name}, years={years}\")\n    data.to_json(cache, orient=\"records\", date_format=\"iso\")\n    print(f\"downloaded {cache.name} ({len(data):,} rows)\")\n    return data\n\n\ndef clean_bea_table(raw):\n    df = raw.copy()\n    df[\"line\"] = pd.to_numeric(df[\"LineNumber\"], errors=\"coerce\").astype(\"Int64\")\n    df[\"description\"] = df[\"LineDescription\"].astype(str)\n    df[\"date\"] = pd.to_datetime(df[\"TimePeriod\"].astype(str).str.replace(\"M\", \"-\", regex=False) + \"-01\")\n    df[\"value\"] = pd.to_numeric(df[\"DataValue\"].astype(str).str.replace(\",\", \"\", regex=False), errors=\"coerce\")\n    return df.dropna(subset=[\"line\", \"date\", \"value\"])[[\"line\", \"description\", \"date\", \"value\"]]\n\n\ndef load_pce_components(line_items, start_date=PCE_START_DATE, force=False):\n    line_items = sorted(int(x) for x in line_items)\n    years = bea_years_needed(start_date)\n    prices = clean_bea_table(fetch_bea_table(PCE_PRICE_TABLE, years, force=force))\n    spending = clean_bea_table(fetch_bea_table(PCE_EXPENDITURE_TABLE, years, force=force))\n\n    prices = prices.loc[prices[\"line\"].isin(line_items)].copy()\n    spending = spending.loc[spending[\"line\"].isin(line_items)].copy()\n    if prices.empty:\n        raise ValueError(f\"No BEA price-index rows found for {line_items}\")\n    if spending.empty:\n        raise ValueError(f\"No BEA expenditure rows found for {line_items}\")\n\n    prices = prices.sort_values([\"line\", \"date\"])\n    prices[\"line_mom_inflation\"] = prices.groupby(\"line\")[\"value\"].pct_change() * 100\n    prices = prices.rename(columns={\"value\": \"price_index\"})\n\n    spending = spending.sort_values([\"line\", \"date\"])\n    spending[\"lagged_expenditure\"] = spending.groupby(\"line\")[\"value\"].shift(1)\n    spending = spending.rename(columns={\"value\": \"expenditure\"})\n\n    merged = prices.merge(\n        spending[[\"line\", \"date\", \"expenditure\", \"lagged_expenditure\"]],\n        on=[\"line\", \"date\"],\n        how=\"left\",\n    )\n    merged[\"lagged_expenditure_share\"] = (\n        merged[\"lagged_expenditure\"] / merged.groupby(\"date\")[\"lagged_expenditure\"].transform(\"sum\")\n    )\n    merged = merged.loc[merged[\"date\"] >= pd.Timestamp(start_date)].copy()\n    return merged\n\n\npce_line_items = sorted(set(BTOS_TO_PCE_LINE.values()))\npce_components = load_pce_components(pce_line_items, force=REFRESH_BEA_INPUTS)\n\npce_descriptions = (\n    pce_components[[\"line\", \"description\"]]\n    .drop_duplicates()\n    .sort_values(\"line\")\n    .reset_index(drop=True)\n)\npce_descriptions\n"
  },
