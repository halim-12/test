   "source": "def load_btos_source(source_name):\n    spec = CENSUS_WORKBOOKS[source_name]\n    workbook = spec[\"path\"]\n    df = pd.read_excel(workbook, sheet_name=spec[\"sheet\"])\n    df[\"sector\"] = df[\"Sector\"].astype(str).str.strip()\n    df[\"question_id\"] = pd.to_numeric(df[\"Question ID\"], errors=\"coerce\")\n    df[\"answer\"] = df[\"Answer\"].astype(str).str.strip()\n\n    row_mask = (\n        df[\"sector\"].isin(BTOS_TO_PCE_LINE)\n        & df[\"question_id\"].eq(Q_ADOPTED)\n        & df[\"answer\"].eq(ANSWER_YES)\n    )\n    rows = df.loc[row_mask].copy()\n    if rows.empty:\n        raise ValueError(f\"No BTOS Q{Q_ADOPTED} / {ANSWER_YES} rows found in {workbook.name}\")\n\n    cols = period_columns(rows)\n    long = rows.melt(\n        id_vars=[\"sector\"],\n        value_vars=cols,\n        var_name=\"period\",\n        value_name=\"ai_adoption\",\n    )\n    long[\"period\"] = long[\"period\"].map(lambda x: int(normalize_period_label(x)))\n    long[\"ai_adoption\"] = long[\"ai_adoption\"].map(parse_percent)\n    long = long.dropna(subset=[\"ai_adoption\"])\n    long[\"source\"] = source_name\n    long[\"source_label\"] = spec[\"label\"]\n    long[\"pce_line\"] = long[\"sector\"].map(BTOS_TO_PCE_LINE).astype(int)\n    long[\"sector_name\"] = long[\"sector\"].map(SECTOR_NAMES)\n\n    dates = collection_date_lookup(workbook)\n    long = long.merge(dates, on=\"period\", how=\"left\")\n    long = long.dropna(subset=[\"month\"])\n    return long[[\n        \"source\", \"source_label\", \"sector\", \"sector_name\", \"pce_line\", \"period\",\n        \"survey_start\", \"survey_end\", \"survey_midpoint\", \"month\", \"ai_adoption\"\n    ]]\n\n\ndef load_btos_waves(mode=BTOS_SERIES_MODE):\n    if mode == \"legacy\":\n        pieces = [load_btos_source(\"legacy\")]\n    elif mode == \"revised\":\n        pieces = [load_btos_source(\"revised\")]\n    elif mode == \"combined\":\n        pieces = [load_btos_source(\"legacy\"), load_btos_source(\"revised\")]\n    else:\n        raise ValueError(\"BTOS_SERIES_MODE must be 'combined', 'legacy', or 'revised'\")\n\n    waves = pd.concat(pieces, ignore_index=True)\n    source_rank = {\"legacy\": 0, \"revised\": 1}\n    waves[\"source_rank\"] = waves[\"source\"].map(source_rank).fillna(0)\n    waves = (\n        waves.sort_values([\"sector\", \"period\", \"source_rank\"])\n        .drop_duplicates([\"sector\", \"period\"], keep=\"last\")\n        .drop(columns=\"source_rank\")\n        .sort_values([\"sector\", \"survey_midpoint\"])\n        .reset_index(drop=True)\n    )\n    return waves\n\n\nensure_census_workbooks(force=REFRESH_CENSUS_INPUTS)\nbtos_waves = load_btos_waves()\n\nbtos_monthly_sector = (\n    btos_waves\n    .groupby([\"sector\", \"sector_name\", \"pce_line\", \"month\"], as_index=False)\n    .agg(\n        ai_adoption=(\"ai_adoption\", \"mean\"),\n        n_btos_waves=(\"period\", \"nunique\"),\n        first_midpoint=(\"survey_midpoint\", \"min\"),\n        last_midpoint=(\"survey_midpoint\", \"max\"),\n        sources=(\"source\", lambda x: \", \".join(sorted(set(x)))),\n    )\n)\n\nbtos_monthly_sector.head()\n"
  },
