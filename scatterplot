   "source": "# Download switches. Keep these False for reproducible runs from the local cache.\nREFRESH_CENSUS_INPUTS = False\nREFRESH_BEA_INPUTS = False\n\n# BTOS source choices: \"combined\", \"legacy\", or \"revised\".\nBTOS_SERIES_MODE = \"combined\"\nBTOS_DATE_BASIS = \"collection\"  # \"collection\" or \"reference\"\n\nQ_ADOPTED = 7\nANSWER_YES = \"Yes\"\nPCE_START_DATE = \"2023-01-01\"\n\nSECTOR_NAMES = {\n    \"11\": \"Agriculture, Forestry, Fishing & Hunting\",\n    \"21\": \"Mining, Quarrying, & Oil and Gas Extraction\",\n    \"22\": \"Utilities\",\n    \"23\": \"Construction\",\n    \"31\": \"Manufacturing\",\n    \"42\": \"Wholesale Trade\",\n    \"44\": \"Retail Trade\",\n    \"48\": \"Transportation and Warehousing\",\n    \"51\": \"Information\",\n    \"52\": \"Finance and Insurance\",\n    \"53\": \"Real Estate and Rental and Leasing\",\n    \"54\": \"Professional, Scientific, and Technical Services\",\n    \"55\": \"Management of Companies and Enterprises\",\n    \"56\": \"Administrative & Waste Services\",\n    \"61\": \"Educational Services\",\n    \"62\": \"Health Care and Social Assistance\",\n    \"71\": \"Arts, Entertainment, and Recreation\",\n    \"72\": \"Accommodation and Food Services\",\n    \"81\": \"Other Services (except Public Administration)\",\n}\n\nBTOS_TO_PCE_LINE = {\n    \"22\": 165,  # Household utilities\n    \"48\": 190,  # Transportation services\n    \"51\": 298,  # Professional and other services\n    \"52\": 252,  # Financial services and insurance\n    \"53\": 298,  # Professional and other services\n    \"54\": 298,  # Professional and other services\n    \"55\": 298,  # Professional and other services\n    \"56\": 165,  # Household utilities\n    \"61\": 290,  # Education services\n    \"62\": 172,  # Health care\n    \"71\": 209,  # Recreation services\n    \"72\": 234,  # Food services and accommodations\n}\n\nEXCLUDED_BTOS_SECTORS = [\"11\", \"21\", \"23\", \"31\", \"42\", \"81\"]\n\n# Optional override for within-PCE-line sector allocation.\n# Example: {298: {\"51\": 0.25, \"53\": 0.15, \"54\": 0.50, \"55\": 0.10}}\n# Leave empty for equal sector weights within each PCE line.\nWITHIN_LINE_SECTOR_WEIGHTS = {}\n\nPLOT_PNG = ROOT / \"pce_weighted_ai_adoption_vs_services_inflation_scatter.png\"\nPLOT_SVG = ROOT / \"pce_weighted_ai_adoption_vs_services_inflation_scatter.svg\"\nOUTPUT_CSV = ROOT / \"pce_weighted_ai_adoption_services_inflation_monthly.csv\"\n"
