   "source": "def read_bea_key(path=API_KEYS):\n    if not path.exists():\n        raise FileNotFoundError(f\"BEA API key file not found: {path}\")\n    for line in path.read_text(encoding=\"utf-8\").splitlines():\n        if line.strip().upper().startswith(\"BEA:\"):\n            return line.split(\":\", 1)[1].strip()\n    raise ValueError(f\"No BEA key found in {path}\")\n\n\ndef download_file(url, path, force=False, min_size=50_000):\n    path = Path(path)\n    if path.exists() and path.stat().st_size >= min_size and not force:\n        print(f\"cached    {path.name}\")\n        return path\n    request = Request(url, headers={\"User-Agent\": \"Mozilla/5.0\"})\n    with urlopen(request, timeout=120) as response:\n        payload = response.read()\n    if len(payload) < min_size:\n        raise RuntimeError(f\"Downloaded file is unexpectedly small: {path.name} ({len(payload):,} bytes)\")\n    path.write_bytes(payload)\n    print(f\"downloaded {path.name} ({len(payload):,} bytes)\")\n    return path\n\n\ndef ensure_census_workbooks(force=False):\n    for spec in CENSUS_WORKBOOKS.values():\n        download_file(spec[\"url\"], spec[\"path\"], force=force)\n\n\ndef normalize_period_label(value):\n    label = str(value).strip()\n    if label.endswith(\".0\"):\n        label = label[:-2]\n    return label\n\n\ndef period_columns(df):\n    cols = []\n    for col in df.columns:\n        label = normalize_period_label(col)\n        if label.isdigit() and len(label) == 6 and 200000 < int(label) < 300000:\n            cols.append(col)\n    return sorted(cols, key=lambda c: int(normalize_period_label(c)))\n\n\ndef parse_percent(value):\n    if pd.isna(value):\n        return np.nan\n    text = str(value).strip()\n    if text in {\"\", \".\", \"S\", \"NA\", \"nan\", \"None\"}:\n        return np.nan\n    if text.endswith(\"%\"):\n        text = text[:-1]\n    try:\n        return float(text)\n    except ValueError:\n        return np.nan\n\n\ndef find_column(df, candidates):\n    lookup = {str(col).strip().lower(): col for col in df.columns}\n    for candidate in candidates:\n        key = candidate.strip().lower()\n        if key in lookup:\n            return lookup[key]\n    raise KeyError(f\"None of these columns were found: {candidates}\")\n\n\ndef collection_date_lookup(workbook, date_basis=BTOS_DATE_BASIS):\n    dates = pd.read_excel(workbook, sheet_name=\"Collection and Reference Dates\")\n    smpdt_col = find_column(dates, [\"Smpdt\"])\n    if date_basis == \"collection\":\n        start_col = find_column(dates, [\"Collection Start\", \"Col Start\"])\n        end_col = find_column(dates, [\"Col End\", \"Collection End\"])\n    elif date_basis == \"reference\":\n        start_col = find_column(dates, [\"Reference Period Start\", \"Ref Start\"])\n        end_col = find_column(dates, [\"Ref End\", \"Reference Period End\"])\n    else:\n        raise ValueError(\"BTOS_DATE_BASIS must be 'collection' or 'reference'\")\n\n    out = dates[[smpdt_col, start_col, end_col]].copy()\n    out = out[pd.to_numeric(out[smpdt_col], errors=\"coerce\").notna()]\n    out[\"period\"] = pd.to_numeric(out[smpdt_col], errors=\"coerce\").astype(int)\n    out[\"survey_start\"] = pd.to_datetime(out[start_col], errors=\"coerce\")\n    out[\"survey_end\"] = pd.to_datetime(out[end_col], errors=\"coerce\")\n    out = out.dropna(subset=[\"period\", \"survey_start\", \"survey_end\"])\n    out[\"survey_midpoint\"] = out[\"survey_start\"] + (out[\"survey_end\"] - out[\"survey_start\"]) / 2\n    out[\"month\"] = out[\"survey_midpoint\"].dt.to_period(\"M\").dt.to_timestamp()\n    return out[[\"period\", \"survey_start\", \"survey_end\", \"survey_midpoint\", \"month\"]]\n"
  },
