   "source": "def build_monthly_analysis(line_ai, pce):\n    line_ai_for_merge = line_ai.rename(columns={\"month\": \"date\"})\n    merged = pce.merge(line_ai_for_merge, left_on=[\"line\", \"date\"], right_on=[\"pce_line\", \"date\"], how=\"inner\")\n\n    merged[\"weighted_ai_contribution\"] = merged[\"line_ai_adoption\"] * merged[\"lagged_expenditure_share\"]\n    merged[\"weighted_inflation_contribution\"] = merged[\"line_mom_inflation\"] * merged[\"lagged_expenditure_share\"]\n\n    expected_lines = pce[\"line\"].nunique()\n    monthly = (\n        merged.dropna(subset=[\n            \"line_ai_adoption\", \"line_mom_inflation\", \"lagged_expenditure_share\",\n            \"weighted_ai_contribution\", \"weighted_inflation_contribution\",\n        ])\n        .groupby(\"date\", as_index=False)\n        .agg(\n            pce_weighted_ai_adoption=(\"weighted_ai_contribution\", \"sum\"),\n            pce_weighted_mom_inflation=(\"weighted_inflation_contribution\", \"sum\"),\n            lagged_expenditure=(\"lagged_expenditure\", \"sum\"),\n            weight_sum=(\"lagged_expenditure_share\", \"sum\"),\n            line_count=(\"line\", \"nunique\"),\n            n_btos_waves=(\"n_btos_waves\", \"sum\"),\n        )\n    )\n\n    monthly = monthly.loc[\n        monthly[\"line_count\"].eq(expected_lines) & np.isclose(monthly[\"weight_sum\"], 1.0)\n    ].copy()\n    monthly[\"year\"] = monthly[\"date\"].dt.year\n    monthly[\"month_label\"] = monthly[\"date\"].dt.strftime(\"%b %Y\")\n    return merged, monthly\n\n\nline_month_detail, monthly_analysis = build_monthly_analysis(pce_line_ai, pce_components)\nmonthly_analysis.to_csv(OUTPUT_CSV, index=False)\n\nprint(f\"Saved monthly analysis to {OUTPUT_CSV}\")\nprint(f\"Months in final scatter: {monthly_analysis['date'].min():%Y-%m} to {monthly_analysis['date'].max():%Y-%m} ({len(monthly_analysis)} months)\")\nmonthly_analysis.tail(10)\n"
