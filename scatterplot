   "source": "mapping_table = pd.DataFrame([\n    {\n        \"btos_sector\": sector,\n        \"btos_sector_name\": SECTOR_NAMES.get(sector, \"\"),\n        \"pce_line\": int(line),\n    }\n    for sector, line in BTOS_TO_PCE_LINE.items()\n]).merge(pce_descriptions.rename(columns={\"line\": \"pce_line\", \"description\": \"pce_description\"}), on=\"pce_line\", how=\"left\")\n\nexcluded_table = pd.DataFrame({\n    \"excluded_btos_sector\": EXCLUDED_BTOS_SECTORS,\n    \"excluded_sector_name\": [SECTOR_NAMES.get(sector, \"\") for sector in EXCLUDED_BTOS_SECTORS],\n})\n\ndisplay(mapping_table.sort_values([\"pce_line\", \"btos_sector\"]).reset_index(drop=True))\ndisplay(excluded_table)\ndisplay(line_ai_coverage)\n"
