   "source": "def year_palette(years):\n    base = [\n        \"#1f77b4\", \"#d62728\", \"#2ca02c\", \"#9467bd\", \"#ff7f0e\",\n        \"#17becf\", \"#8c564b\", \"#7f7f7f\", \"#bcbd22\",\n    ]\n    return {year: base[i % len(base)] for i, year in enumerate(sorted(years))}\n\n\ndef render_svg_scatter(data, path=PLOT_SVG):\n    plot = data.sort_values(\"date\").copy()\n    width, height = 920, 620\n    left, right, top, bottom = 92, 226, 56, 96\n    inner_w = width - left - right\n    inner_h = height - top - bottom\n\n    x = plot[\"pce_weighted_ai_adoption\"].astype(float)\n    y = plot[\"pce_weighted_mom_inflation\"].astype(float)\n    x_pad = max((x.max() - x.min()) * 0.08, 0.5)\n    y_pad = max((y.max() - y.min()) * 0.12, 0.05)\n    x_min, x_max = x.min() - x_pad, x.max() + x_pad\n    y_min, y_max = min(0, y.min() - y_pad), y.max() + y_pad\n\n    colors = year_palette(plot[\"year\"].unique())\n\n    def sx(value):\n        return left + (float(value) - x_min) / (x_max - x_min) * inner_w\n\n    def sy(value):\n        return top + (y_max - float(value)) / (y_max - y_min) * inner_h\n\n    def tick_values(vmin, vmax, n=6):\n        return np.linspace(vmin, vmax, n)\n\n    lines = []\n    lines.append(f'<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"{width}\" height=\"{height}\" viewBox=\"0 0 {width} {height}\">')\n    lines.append('<rect width=\"100%\" height=\"100%\" fill=\"white\"/>')\n    lines.append('<style>text{font-family:Arial,Helvetica,sans-serif;fill:#222} .small{font-size:12px}.axis{stroke:#222;stroke-width:1}.grid{stroke:#e1e4e8;stroke-width:1}</style>')\n    lines.append(f'<text x=\"{left}\" y=\"30\" font-size=\"20\" font-weight=\"700\">PCE-weighted AI adoption vs. mapped services inflation</text>')\n    lines.append(f'<text x=\"{left}\" y=\"50\" class=\"small\" fill=\"#555\">Monthly dots; color indicates calendar year. Inflation is non-annualized m/m percent change.</text>')\n\n    for value in tick_values(y_min, y_max):\n        yy = sy(value)\n        lines.append(f'<line x1=\"{left}\" x2=\"{width-right}\" y1=\"{yy:.1f}\" y2=\"{yy:.1f}\" class=\"grid\"/>')\n        lines.append(f'<text x=\"{left-10}\" y=\"{yy+4:.1f}\" class=\"small\" text-anchor=\"end\">{value:.2f}</text>')\n    for value in tick_values(x_min, x_max):\n        xx = sx(value)\n        lines.append(f'<line x1=\"{xx:.1f}\" x2=\"{xx:.1f}\" y1=\"{top}\" y2=\"{height-bottom}\" class=\"grid\"/>')\n        lines.append(f'<text x=\"{xx:.1f}\" y=\"{height-bottom+24}\" class=\"small\" text-anchor=\"middle\">{value:.1f}</text>')\n\n    if y_min <= 0 <= y_max:\n        yy0 = sy(0)\n        lines.append(f'<line x1=\"{left}\" x2=\"{width-right}\" y1=\"{yy0:.1f}\" y2=\"{yy0:.1f}\" stroke=\"#444\" stroke-width=\"1.2\"/>')\n\n    lines.append(f'<line x1=\"{left}\" x2=\"{left}\" y1=\"{top}\" y2=\"{height-bottom}\" class=\"axis\"/>')\n    lines.append(f'<line x1=\"{left}\" x2=\"{width-right}\" y1=\"{height-bottom}\" y2=\"{height-bottom}\" class=\"axis\"/>')\n    lines.append(f'<text x=\"{left + inner_w/2}\" y=\"{height-38}\" font-size=\"14\" text-anchor=\"middle\">PCE-weighted AI adoption (percent of firms)</text>')\n    lines.append(f'<text x=\"22\" y=\"{top + inner_h/2}\" font-size=\"14\" text-anchor=\"middle\" transform=\"rotate(-90 22 {top + inner_h/2})\">PCE-weighted m/m inflation (percent)</text>')\n\n    coords = [(sx(row.pce_weighted_ai_adoption), sy(row.pce_weighted_mom_inflation)) for row in plot.itertuples()]\n    if len(coords) > 1:\n        points = \" \".join(f\"{xx:.1f},{yy:.1f}\" for xx, yy in coords)\n        lines.append(f'<polyline points=\"{points}\" fill=\"none\" stroke=\"#999\" stroke-width=\"1\" opacity=\"0.45\"/>')\n\n    for row in plot.itertuples():\n        xx = sx(row.pce_weighted_ai_adoption)\n        yy = sy(row.pce_weighted_mom_inflation)\n        color = colors[int(row.year)]\n        label = row.date.strftime(\"%b %Y\")\n        lines.append(f'<circle cx=\"{xx:.1f}\" cy=\"{yy:.1f}\" r=\"6\" fill=\"{color}\" stroke=\"white\" stroke-width=\"1.3\"><title>{label}: AI {row.pce_weighted_ai_adoption:.2f}%, inflation {row.pce_weighted_mom_inflation:.3f}%</title></circle>')\n\n    legend_x = width - right + 40\n    legend_y = top + 18\n    lines.append(f'<text x=\"{legend_x}\" y=\"{legend_y}\" font-size=\"13\" font-weight=\"700\">Year</text>')\n    for i, year in enumerate(sorted(colors)):\n        yy = legend_y + 24 + i * 24\n        lines.append(f'<circle cx=\"{legend_x+7}\" cy=\"{yy-4}\" r=\"6\" fill=\"{colors[year]}\"/>')\n        lines.append(f'<text x=\"{legend_x+24}\" y=\"{yy}\" class=\"small\">{year}</text>')\n\n    latest = plot.iloc[-1]\n    lines.append(f'<text x=\"{left}\" y=\"{height-12}\" class=\"small\" fill=\"#555\">Source: Authors calculations from Census BTOS and BEA NIPA underlying detail. Latest plotted month: {latest.date:%B %Y}.</text>')\n    lines.append('</svg>')\n    svg = \"\\n\".join(lines)\n    path.write_text(svg, encoding=\"utf-8\")\n    return svg\n\n\ndef plot_scatter(data):\n    plot = data.sort_values(\"date\").copy()\n    colors = year_palette(plot[\"year\"].unique())\n    try:\n        import matplotlib.pyplot as plt\n        fig, ax = plt.subplots(figsize=(7.6, 5.0), dpi=160)\n        ax.plot(\n            plot[\"pce_weighted_ai_adoption\"],\n            plot[\"pce_weighted_mom_inflation\"],\n            color=\"#999999\",\n            linewidth=0.9,\n            alpha=0.45,\n            zorder=1,\n        )\n        for year, group in plot.groupby(\"year\"):\n            ax.scatter(\n                group[\"pce_weighted_ai_adoption\"],\n                group[\"pce_weighted_mom_inflation\"],\n                s=48,\n                color=colors[int(year)],\n                edgecolor=\"white\",\n                linewidth=0.8,\n                label=str(int(year)),\n                zorder=3,\n            )\n        ax.axhline(0, color=\"#333333\", linewidth=0.9)\n        ax.grid(True, color=\"#e1e4e8\", linewidth=0.7)\n        ax.set_xlabel(\"PCE-weighted AI adoption (percent of firms)\")\n        ax.set_ylabel(\"PCE-weighted m/m inflation (percent)\")\n        ax.set_title(\"PCE-weighted AI adoption vs. mapped services inflation\", loc=\"left\", weight=\"bold\", pad=12)\n        ax.text(\n            0.0, 1.01,\n            \"Monthly dots; colors indicate calendar year. Inflation is non-annualized m/m percent change.\",\n            transform=ax.transAxes,\n            ha=\"left\",\n            va=\"bottom\",\n            fontsize=8.5,\n            color=\"#555555\",\n        )\n        ax.legend(title=\"Year\", frameon=False, loc=\"best\")\n        fig.text(0.11, 0.02, \"Source: Authors' calculations from Census BTOS and BEA NIPA underlying detail.\", fontsize=8, color=\"#555555\")\n        fig.tight_layout(rect=[0, 0.04, 1, 1])\n        fig.savefig(PLOT_PNG, dpi=200, bbox_inches=\"tight\")\n        print(f\"Saved plot to {PLOT_PNG}\")\n        return fig, ax\n    except ModuleNotFoundError as exc:\n        if exc.name != \"matplotlib\":\n            raise\n        svg = render_svg_scatter(plot)\n        print(f\"matplotlib is not installed; saved SVG fallback to {PLOT_SVG}\")\n        if SVG is not None:\n            display(SVG(svg))\n        return svg\n\n\nplot_scatter(monthly_analysis)\n"
